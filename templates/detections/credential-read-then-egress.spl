``` EXAMPLE Splunk SPL — compiled illustration of credential-read-then-egress.yml.
    Replace index names and fields with your agent audit log + endpoint/network telemetry.
    The intent: for each agent, find a credential-path read followed by an outbound
    connection within 5 minutes, to a destination NOT on the egress allowlist. ```

(index=agent_audit (action=file_read OR event=file_read)
    (path="*/.aws/*" OR path="*/.ssh/*" OR path="*/.config/gcloud/*"
     OR path="*.env" OR path="*credentials*" OR path="*.pem" OR path="*.key"))
OR
(index=agent_audit action=network_connect direction=outbound dest_allowlisted=false)
| eval phase=if(action="file_read","cred_read","egress")
| transaction agent_id maxspan=5m startswith=(phase="cred_read") endswith=(phase="egress")
| where eventcount>=2
| table _time agent_id user path dest dest_port
| sort - _time
