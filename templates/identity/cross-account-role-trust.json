{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowScopedCrossAccountAssume",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::111122223333:role/agent-runner"
      },
      "Action": "sts:AssumeRole",
      "Condition": {
        "StringEquals": {
          "sts:ExternalId": "REPLACE-WITH-A-SECRET-EXTERNAL-ID"
        }
      }
    }
  ]
}
